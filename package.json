{
  "name": "insitu-ads",
  "private": true,
  "version": "1.0.0",
  "description": "Plataforma integral de optimización y planning de advertising impulsada por IA. Herramientas de auditoría creativa, análisis competitivo y gestión de identidad de marca.",
  "author": "INsitu AI / Franklin Sanchez",
  "license": "Proprietary",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/security_check.js && node generate-sitemap.js",
    "prebuild:desktop": "bash scripts/download_ollama.sh",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.js",
    "deploy": "npm run build && zip -r production_update.zip dist server package.json package-lock.json -x \"server/database.sqlite\" \"server/insitu.db\" \"server/*.db\" \"server/*.sqlite\"",
    "tauri:gen-keys": "bash scripts/generate-tauri-keys.sh",
    "version": "bash scripts/sync-version.sh",
    "app:check-update": "npx tauri --version",
    "app:update": "npm run build && npx tauri build"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.40.0",
    "@gsap/react": "^2.1.2",
    "@paypal/react-paypal-js": "^8.9.2",
    "@tauri-apps/api": "^2.11.0",
    "@types/dompurify": "^3.0.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.16.1",
    "body-parser": "^2.2.2",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "google-auth-library": "^10.6.2",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "postgres": "^3.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "recharts": "^3.7.0",
    "sqlite3": "^5.1.7",
    "tar": "^7.5.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "netlify-cli": "^23.15.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
