{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "INsitu AI",
  "version": "1.0.0",
  "identifier": "ai.insitu.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "INsitu AI Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:* http://localhost:* https://*.supabase.co wss://*.supabase.co https://insitu.company https://*.netlify.app https://*.googleapis.com https://openrouter.ai"
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/ollama"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://insitu.company/updater/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzRTUyQTY4N0NCOEJEODAKUldTc1VnOXZlYjB2dEZ6NW9qRmI5SDB5Z0gzd0tINnlzVEdqREpIeWd0eGZNSG12aWVraTZPNEkK"
    }
  }
}
